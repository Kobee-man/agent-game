# ==================== LLM 配置 ====================
# 模式: "external" (DeepSeek/OpenAI兼容) 或 "local" (Ollama)
LLM_MODE=external
LLM_API_KEY=your-api-key-here
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_MODEL=deepseek-chat
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=1000

# 本地模式 (Ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b

# ==================== 数据库 ====================
# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/fastapi_chat
# SQLite (备用)
# DATABASE_URL=sqlite:///./turtle_soup.db

# ==================== 安全 ====================
SECRET_KEY=change-me-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Redis (可选) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== Embedding ====================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ==================== 向量库 ====================
VECTOR_COLLECTION_PREFIX=htg_
VECTOR_SEARCH_TOP_K=5
VECTOR_DISTANCE_THRESHOLD=0.7
